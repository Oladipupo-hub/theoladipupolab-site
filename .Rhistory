# ---------- Install + load required packages ----------
pkgs <- c("ggplot2", "dplyr", "tidyr", "cowplot", "showtext", "sysfonts")
to_install <- pkgs[!sapply(pkgs, requireNamespace, quietly = TRUE)]
if (length(to_install) > 0) install.packages(to_install)
library(ggplot2)
library(dplyr)
library(tidyr)
library(cowplot)
library(showtext)
library(sysfonts)
